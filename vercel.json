{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/wordpress", "destination": "/", "permanent": true },
    { "source": "/wordpress/", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/:slug", "destination": "/post.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
